# ============================================================
# MedVerify AI — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=MedVerify AI
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-minimum-64-characters-change-in-production
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8000"]

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medverify
POSTGRES_USER=medverify_user
POSTGRES_PASSWORD=medverify_secret
DATABASE_URL=postgresql+asyncpg://medverify_user:medverify_secret@localhost:5432/medverify
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_URL=redis://:redis_secret@localhost:6379/0
CACHE_TTL_SECONDS=3600
RATE_LIMIT_WINDOW_SECONDS=60

# ── Qdrant Vector DB ──────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=medical_documents
QDRANT_VECTOR_SIZE=1024

# ── LLM Providers ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=4096

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

DEFAULT_LLM_MODEL=gpt-4o

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# ── Ingestion ─────────────────────────────────────────────────
NCBI_API_KEY=your-ncbi-api-key
PUBMED_MAX_RESULTS=1000
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64

# ── Observability ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=medverify-dev
LANGSMITH_TRACING=false
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── RAGAS / DeepEval ──────────────────────────────────────────
RAGAS_BATCH_SIZE=5
DEEPEVAL_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ASK=30
RATE_LIMIT_VERIFY=60
RATE_LIMIT_DEFAULT=100

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
